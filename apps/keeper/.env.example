# PredictionHouse keeper config. Copy to .env and fill in. Keep .env chmod 600.
RPC_URL=https://k8s.testnet.json-rpc.injective.network/
HOUSE_ADDR=0xe7773Db880BF38574441699A60E53d68a52Db680

# Signer — use a DEDICATED keeper key on mainnet (fund it with a little INJ for gas).
# Exactly one of these:
KEEPER_PRIVATE_KEY=
# KEEPER_MNEMONIC=

# WSS for block-driven firing (fires lock/settle the first eligible block). HTTP above is used for
# reads + tx sends; WSS is only the fast trigger and auto-reconnects.
WSS_URL=wss://k8s.testnet.ws.injective.network/

# Optional (tuned for 15s rounds)
HERMES_URL=https://hermes.pyth.network
LEAD_SEC=8
FALLBACK_MS=6000
ACTION_COOLDOWN=4
GAS_LIMIT=2500000
