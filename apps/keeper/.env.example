# PredictionBook sweeper config. Copy to .env and fill in. Keep .env chmod 600.
RPC_URL=https://k8s.testnet.json-rpc.injective.network/
BOOK_ADDR=0x0000000000000000000000000000000000000000

# Signer — use a DEDICATED keeper key (NOT the deployer). Fund it with INJ: this keeper is
# SUBSIDISED (it pays gas + Pyth fees to settle; the escrow tip may not cover cost at low volume).
# Exactly one of these:
KEEPER_PRIVATE_KEY=
# KEEPER_MNEMONIC=

# WSS for block-driven sweeping (settles matured bets the first eligible block). HTTP above is used
# for reads + tx sends; WSS is only the fast trigger and auto-reconnects.
WSS_URL=wss://k8s.testnet.ws.injective.network/

# Optional
HERMES_URL=https://hermes.pyth.network
PAGE=500            # positions scanned per pendingSettlement call
MAX_SETTLE=20       # max bets per settleMany tx (bounds gas)
FALLBACK_MS=6000
ACTION_COOLDOWN=6   # don't re-send a bet within this many seconds
GAS_LIMIT=6000000
FEE_BUFFER_BPS=500  # pad the Pyth update fee 5% (contract refunds leftover)
