# ===== MAINNET keeper config (chainid 1776) — copy to .env.mainnet, chmod 600 =====
# Consumed by helix-keeper-mainnet.service. The TESTNET keeper uses .env (see .env.example).
# Same keeper key funds both chains; each env just points at a different network + book.
RPC_URL=https://sentry.evm-rpc.injective.network/
WSS_URL=wss://sentry.evm-ws.injective.network/
BOOK_ADDR=0x98121Af94Ece69bFEC46544ff0Fc202F30010956

# Dedicated keeper key (NOT the deployer). Fund with INJ on MAINNET. Exactly one of:
KEEPER_PRIVATE_KEY=
# KEEPER_MNEMONIC=

HERMES_URL=https://hermes.pyth.network
PAGE=500
MAX_SETTLE=20
FALLBACK_MS=6000
ACTION_COOLDOWN=6
GAS_LIMIT=6000000
FEE_BUFFER_BPS=500
