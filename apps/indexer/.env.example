# ===== helix-predict leaderboard indexer (Phase 2 global board) — copy to .env.mainnet, chmod 600 =====
# Runs as helix-indexer.service, SEPARATE from the keeper (own RPC budget, hardened unit).
RPC_URL=https://sentry.evm-rpc.injective.network/
BOOK_ADDR=0x98121Af94Ece69bFEC46544ff0Fc202F30010956
DEPLOY_BLOCK=173753444          # book first-code block = cursor seed (never re-scan below this)

DB_PATH=/opt/helix-predict/apps/indexer/data/leaderboard.db
OUT_DIR=/opt/helix-predict/apps/indexer/public
LAG_BLOCKS=6                     # lag the head (load-balanced RPC eventual-consistency; finality is instant)
POLL_MS=60000                   # index+publish cadence

# Publish leaderboard.json (+ _headers) to the dedicated CF Pages project. Frontend fetches
# https://helix-leaderboard.pages.dev/leaderboard.json. Needs the two CF vars below.
PUBLISH_CMD=npx --yes wrangler@3 pages deploy ./public --project-name=helix-leaderboard --branch=main --commit-dirty=true
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=2442a93ef1725a04ed3903139ae48bc7
